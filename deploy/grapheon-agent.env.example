# Base Graphēon URL. Use HTTPS in production.
GRAPHEON_AGENT_SERVER_URL=https://grapheon.example.com

# Admin-created enrollment key used until the backend issues a per-agent API key.
GRAPHEON_AGENT_ENROLLMENT_KEY=gaek_replace_me

# Optional metadata shown in the Graphēon agent registry.
# GRAPHEON_AGENT_DISPLAY_NAME=Branch Router 01
# GRAPHEON_AGENT_SITE_NAME=Boise
# GRAPHEON_AGENT_HOSTNAME=branch-router-01

# Local state location for agent_uuid, API key, and cached snapshot/policy state.
GRAPHEON_AGENT_STATE_DIR=/var/lib/grapheon-agent

# Local timer cadence. The runtime uses this together with the cached backend
# policy interval to decide whether to perform a full collection on this run.
GRAPHEON_AGENT_TIMER_INTERVAL_SECONDS=900

# Optional TLS settings for private CAs or lab environments.
# GRAPHEON_AGENT_CA_FILE=/etc/ssl/certs/internal-ca.pem
# GRAPHEON_AGENT_INSECURE_SKIP_VERIFY=false

# Optional runtime tuning.
# GRAPHEON_AGENT_REQUEST_TIMEOUT_SECONDS=30
# GRAPHEON_AGENT_LOG_LEVEL=INFO
